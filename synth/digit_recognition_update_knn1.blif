.inputs data2 data1 addr2[0] addr2[1] addr2[2] addr2[3] addr2[4] addr2[5] addr2[6] addr2[7] addr2[8] addr2[9] addr2[10] \
 addr2[11] addr2[12] addr2[13] addr2[14] addr1[0] addr1[1] addr1[2] addr1[3] addr1[4] addr1[5] addr1[6] addr1[7] addr1[8] \
 addr1[9] addr1[10] addr1[11] addr1[12] addr1[13] addr1[14] we2 we1 clk 


.outputs out2 out1 


.blackbox 



.end 




